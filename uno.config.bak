import { defineConfig, presetWind4 } from "unocss";

const breakpoints = ["sm:", "md:", "lg:", "xl:", "2xl:"];

// Helper to generate base + responsive variants
const makeSafe = (classes: string[]) => {
  return [
    ...classes,
    ...breakpoints.flatMap((bp) => classes.map((c) => `${bp}${c}`)),
  ];
};

export default defineConfig({
  presets: [presetWind4()],
  content: {
    pipeline: {
      include: [/\.(astro|html|[tj]sx|ts|vue)$/],
      exclude: ["**/src/pages/sites/**"],
    },
  },
  safelist: makeSafe([
    // Flex Justify
    "justify-normal", "justify-start", "justify-center", "justify-end",
    "justify-between", "justify-around", "justify-evenly", "justify-stretch",

    // Items Align
    "items-start", "items-center", "items-end", "items-baseline", "items-stretch",

    // Flex Directions
    "flex-row", "flex-col", "flex-row-reverse", "flex-col-reverse",

    // Wrap
    "flex-wrap", "flex-nowrap", "flex-wrap-reverse",

    // Gaps
    ...Array.from({ length: 13 }, (_, i) => `gap-${i * 2}`),

    // Spacing (Paddings)
    "pt-2", "pt-4", "pt-6", "pt-8", "pt-10",
    "pb-2", "pb-4", "pb-6", "pb-8", "pb-10",
  ]),
  theme: {
    colors: { primary: "#f3602a" },
    font: { lineHeight: "1" },
  },
});