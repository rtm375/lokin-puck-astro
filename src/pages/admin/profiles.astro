---
import Layout from "../../layouts/dashboard.astro";
import ProfilesComponent from "../../components/client/Profile";
export const prerender = false;
const { profile, user, t } = Astro.locals;

if (!user) {
  return Astro.redirect("/login");
}

const safeProfile = profile || {
  id: user.id,
  full_name: "",
  bio: "",
  avatar_url: null,
  tier: "free",
  preferences: {},
  storage_used: 0,
};

// Get language for the component
const currentLang = profile?.preferences?.language || "en";
---

<Layout title={t("user_profile.title")}>
  <ProfilesComponent
    client:load
    initialProfile={{ ...safeProfile, email: user.email }}
    currentLang={currentLang}
  />
</Layout>
