---
import Header from "@components/Header.astro";
import Sidebar from "@components/Sidebar.astro";
import { ClientRouter } from "astro:transitions";
import "@/assets/css/global.css";
const { preferences } = Astro.locals;
const { title, type } = Astro.props;
---

<!doctype html>
<html lang={preferences?.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      const root = document.documentElement;
      let theme = "system";
      let lang = "en";

      try {
        const profileStore = JSON.parse(localStorage.getItem("profile"));
        if (
          profileStore &&
          profileStore.state &&
          profileStore.state.profile &&
          profileStore.state.profile.preferences
        ) {
          theme = profileStore.state.profile.preferences.theme || "system";
          lang = profileStore.state.profile.preferences.language || "en";
        }
      } catch (e) {
        console.error("Failed to parse profile from localStorage", e);
      }

      root.lang = lang;

      const applyTheme = (selectedTheme) => {
        if (selectedTheme === "system") {
          const systemDark = window.matchMedia(
            "(prefers-color-scheme: dark)",
          ).matches;
          if (systemDark) {
            root.classList.add("dark");
          } else {
            root.classList.remove("dark");
          }
        } else if (selectedTheme === "dark") {
          root.classList.add("dark");
        } else {
          root.classList.remove("dark");
        }
      };

      applyTheme(theme);

      // Listen for OS changes live if system theme is selected initially
      if (theme === "system") {
        window
          .matchMedia("(prefers-color-scheme: dark)")
          .addEventListener("change", (e) => {
            applyTheme("system"); // Re-apply system theme logic on change
          });
      }
    </script>
  </head>
  <body>
    <div class="flex w-full">
      <aside class="w-52">
        <Sidebar type={type} />
      </aside>
      <main class="grow">
        <div class="w-full h-[calc(100dvh-50px)] overflow-y-auto">
          <div class="flex flex-col gap-y-4">
            <Header title={title} />
            <div class="mx-auto max-w-7xl w-full px-6">
              <slot />
            </div>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
