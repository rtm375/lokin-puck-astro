---
import { Image } from "astro:assets";
import Logo from "@/assets/images/logo-light.svg";
import UserMenu from "@components/UserMenu.astro";
import NavDefaults from "@components/navigation/NavDefaults.astro";
const { type } = Astro.props;
---

<div
  class="flex h-screen flex-col justify-between border-e border-gray-200 bg-white"
>
  <div class="py-4 space-y-6">
    <span class="block h-10 w-32 place-content-center py-2 px-4">
      <Image src={Logo} class="max-h-7 w-auto" alt="Lokin Builder" />
    </span>
    <ul class="space-y-1">
      <NavDefaults />
    </ul>
  </div>
  <div class="sticky inset-x-0 bottom-0 border-t border-gray-200">
    <UserMenu />
  </div>
</div>
