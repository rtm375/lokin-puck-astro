---
import { isActive } from "../../utils";
const { url } = Astro;
const { t } = Astro.locals;
const { slug } = Astro.params;
const { websites } = Astro.props;

const currentWebsite = websites?.find((w: any) => w.slug === slug);
---

<li>
  <a
    href={`/admin/dashboard`}
    class="flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><path
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M6.625 2.75a3.875 3.875 0 1 0 0 7.75a3.875 3.875 0 0 0 0-7.75m10.75 0a3.875 3.875 0 1 0 0 7.75a3.875 3.875 0 0 0 0-7.75M6.625 13.5a3.875 3.875 0 1 0 0 7.75a3.875 3.875 0 0 0 0-7.75m10.75 0a3.875 3.875 0 1 0 0 7.75a3.875 3.875 0 0 0 0-7.75"
      ></path></svg
    >
    <span class="text-sm font-medium">
      {t("navigations.defaults.dashboard")}
    </span>
  </a>
</li>
<li>
  <div class="px-4 py-2 relative flex flex-col gap-2">
    <p class="text-sm">You are editing:</p>
    <div class="relative flex group">
      <span
        class="flex w-full overflow-hidden rounded group-hover:rounded-t group-hover:rounded-b-none border border-gray-300 bg-white shadow-sm dark:divide-gray-600 dark:border-gray-600 dark:bg-gray-800"
      >
        <button
          type="button"
          class="px-3 py-1.5 text-left flex-1 text-sm font-medium transition-colors hover:bg-gray-50 hover:text-gray-900 focus:relative dark:text-gray-200 dark:hover:bg-gray-700 dark:hover:text-white"
        >
          {currentWebsite?.name || "..."}
        </button>

        <button
          type="button"
          class="w-8 flex items-center justify-center text-sm font-medium transition-colors hover:bg-gray-50 hover:text-gray-900 focus:relative dark:text-gray-200 dark:hover:bg-gray-700 dark:hover:text-white"
          aria-label="Menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="size-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
          </svg>
        </button>
      </span>

      <div
        role="menu"
        class="absolute hidden group-hover:block start-0 top-full z-auto w-full divide-y divide-gray-200 overflow-hidden rounded-b border border-t-0 border-gray-300 bg-white shadow-sm dark:border-gray-600 dark:bg-gray-800"
      >
        {
          websites?.map((website: any) => (
            <div>
              <a
                href={`/admin/websites/${website.slug}/pages`}
                class="block px-3 py-2 text-sm font-medium transition-colors hover:bg-gray-50 hover:text-gray-900 dark:text-gray-200 dark:hover:bg-gray-700 dark:hover:text-white"
                role="menuitem"
              >
                {website.name}
              </a>
            </div>
          ))
        }

        <a
          href="/admin/websites"
          type="button"
          class="block w-full px-3 py-2 text-sm font-medium transition-colors hover:bg-red-50 ltr:text-left rtl:text-right"
        >
          All Website
        </a>
      </div>
    </div>
  </div>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/pages`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/pages`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><g
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        ><path
          d="M4 21.4V2.6a.6.6 0 0 1 .6-.6h11.652a.6.6 0 0 1 .424.176l3.148 3.148A.6.6 0 0 1 20 5.75V21.4a.6.6 0 0 1-.6.6H4.6a.6.6 0 0 1-.6-.6M8 10h8m-8 8h8m-8-4h4"
        ></path><path d="M16 2v3.4a.6.6 0 0 0 .6.6H20"></path></g
      ></svg
    >
    <span class="text-sm font-medium"> {t("navigations.websites.pages")} </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/media`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/media`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><g
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        ><path
          d="M21 3.6v16.8a.6.6 0 0 1-.6.6H3.6a.6.6 0 0 1-.6-.6V3.6a.6.6 0 0 1 .6-.6h16.8a.6.6 0 0 1 .6.6"
        ></path><path d="m3 16l7-3l11 5m-5-8a2 2 0 1 1 0-4a2 2 0 0 1 0 4"
        ></path></g
      ></svg
    >
    <span class="text-sm font-medium"> {t("navigations.websites.media")} </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/products`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/products`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 2048 2048"
      ><path
        fill="currentColor"
        d="m960 120l832 416v1040l-832 415l-832-415V536zm625 456L960 264L719 384l621 314zM960 888l238-118l-622-314l-241 120zM256 680v816l640 320v-816zm768 1136l640-320V680l-640 320z"
      ></path></svg
    >
    <span class="text-sm font-medium">
      {t("navigations.websites.products")}
    </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/forms`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/forms`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M6 10.75a2.25 2.25 0 1 1 4.5 0a2.25 2.25 0 0 1-4.5 0M8.25 10a.75.75 0 1 0 0 1.5a.75.75 0 0 0 0-1.5m0 4a2.25 2.25 0 1 0 0 4.5a2.25 2.25 0 0 0 0-4.5m-.75 2.25a.75.75 0 1 1 1.5 0a.75.75 0 0 1-1.5 0m4.5-5.5a.75.75 0 0 1 .75-.75h4.5a.75.75 0 0 1 0 1.5h-4.5a.75.75 0 0 1-.75-.75m.75 4.75a.75.75 0 0 0 0 1.5h4.5a.75.75 0 0 0 0-1.5zM6 6.75A.75.75 0 0 1 6.75 6h10.5a.75.75 0 0 1 0 1.5H6.75A.75.75 0 0 1 6 6.75M6.25 3A3.25 3.25 0 0 0 3 6.25v11.5A3.25 3.25 0 0 0 6.25 21h11.5A3.25 3.25 0 0 0 21 17.75V6.25A3.25 3.25 0 0 0 17.75 3zM4.5 6.25c0-.966.784-1.75 1.75-1.75h11.5c.966 0 1.75.784 1.75 1.75v11.5a1.75 1.75 0 0 1-1.75 1.75H6.25a1.75 1.75 0 0 1-1.75-1.75z"
      ></path></svg
    >
    <span class="text-sm font-medium"> {t("navigations.websites.forms")} </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/appearance`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/appearance`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="m3.975 19.8l-.85-.35q-.775-.325-1.037-1.125t.087-1.575l1.8-3.9zm4 2.2q-.825 0-1.412-.587T5.975 20v-6l2.65 7.35q.075.175.15.338t.2.312zm5.15-.1q-.8.3-1.55-.075t-1.05-1.175l-4.45-12.2q-.3-.8.05-1.562t1.15-1.038l7.55-2.75q.8-.3 1.55.075t1.05 1.175l4.45 12.2q.3.8-.05 1.563t-1.15 1.037zM10.975 10q.425 0 .713-.288T11.975 9t-.287-.712T10.975 8t-.712.288T9.975 9t.288.713t.712.287m1.45 10l7.55-2.75L15.525 5l-7.55 2.75zM7.975 7.75L15.525 5z"
      ></path></svg
    >
    <span class="text-sm font-medium">
      {t("navigations.websites.appearance")}
    </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/users`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/users`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><path
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M5 7a4 4 0 1 0 8 0a4 4 0 1 0-8 0M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2m1-17.87a4 4 0 0 1 0 7.75M21 21v-2a4 4 0 0 0-3-3.85"
      ></path></svg
    >
    <span class="text-sm font-medium"> {t("navigations.websites.users")} </span>
  </a>
</li>
<li>
  <a
    href={`/admin/websites/${slug}/settings`}
    class={`${isActive(url.pathname, `/admin/websites/${slug}/settings`) ? "bg-linear-to-r from-transparent to-gray-100 " : ""} flex items-center gap-2 py-2 px-4 text-gray-800 hover:bg-linear-to-r hover:from-transparent hover:to-gray-100`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      ><path
        fill="currentColor"
        d="M19.9 12.66a1 1 0 0 1 0-1.32l1.28-1.44a1 1 0 0 0 .12-1.17l-2-3.46a1 1 0 0 0-1.07-.48l-1.88.38a1 1 0 0 1-1.15-.66l-.61-1.83a1 1 0 0 0-.95-.68h-4a1 1 0 0 0-1 .68l-.56 1.83a1 1 0 0 1-1.15.66L5 4.79a1 1 0 0 0-1 .48L2 8.73a1 1 0 0 0 .1 1.17l1.27 1.44a1 1 0 0 1 0 1.32L2.1 14.1a1 1 0 0 0-.1 1.17l2 3.46a1 1 0 0 0 1.07.48l1.88-.38a1 1 0 0 1 1.15.66l.61 1.83a1 1 0 0 0 1 .68h4a1 1 0 0 0 .95-.68l.61-1.83a1 1 0 0 1 1.15-.66l1.88.38a1 1 0 0 0 1.07-.48l2-3.46a1 1 0 0 0-.12-1.17ZM18.41 14l.8.9l-1.28 2.22l-1.18-.24a3 3 0 0 0-3.45 2L12.92 20h-2.56L10 18.86a3 3 0 0 0-3.45-2l-1.18.24l-1.3-2.21l.8-.9a3 3 0 0 0 0-4l-.8-.9l1.28-2.2l1.18.24a3 3 0 0 0 3.45-2L10.36 4h2.56l.38 1.14a3 3 0 0 0 3.45 2l1.18-.24l1.28 2.22l-.8.9a3 3 0 0 0 0 3.98m-6.77-6a4 4 0 1 0 4 4a4 4 0 0 0-4-4m0 6a2 2 0 1 1 2-2a2 2 0 0 1-2 2"
      ></path></svg
    >
    <span class="text-sm font-medium">
      {t("navigations.websites.settings")}
    </span>
  </a>
</li>
