---
import { Render } from "@measured/puck";
import { getConfig } from "@/lib/puck.config";
import { generateCss } from "@/lib/css-engine";
import { scriptRegistry } from "@/lib/script-registry";
import { pageCache } from "@/lib/page-cache";

const { supabase, websiteId } = Astro.locals;
const { path } = Astro.params;

if (!websiteId) {
  return new Response("Not Found", { status: 404 });
}

// Set Cache-Control header for CDN and Browser caching
// s-maxage=60: Cloudflare/CDN cache for 60 seconds
// stale-while-revalidate=30: Serve stale content while updating
// max-age=60: Browser cache for 60 seconds
// Astro.response.headers.set("Cache-Control", "public, max-age=60, s-maxage=60, stale-while-revalidate=30");

// Resolve page path
// If path is undefined, it's the root, so look for "home" or "index"
// If path is defined, use it.
// Note: path param in Astro for [...path] is a string, e.g. "about/us"
let pagePath = path;

// Try fetching the page
let page: any = null;
const cacheKey = `${websiteId}:${pagePath}`;
const cachedPage = pageCache.get(cacheKey);

if (cachedPage) {
  console.log("Page Cache Hit:", cacheKey);
  page = cachedPage;
} else {
  console.log("Page Cache Miss:", cacheKey);

  if (pagePath) {
    // Fetch by path
    let { data } = await supabase.from("pages").select("data, title, head_code, is_front_page").eq("website_id", websiteId).eq("path", pagePath).single();
    page = data;

    // Redirect if it's the front page
    if (page && page.is_front_page) {
      return Astro.redirect("/");
    }
  } else {
    // Root request: try is_front_page = true
    let { data } = await supabase.from("pages").select("data, title, head_code, is_front_page").eq("website_id", websiteId).eq("is_front_page", true).single();
    page = data;

    // Fallback to "index"
    if (!page) {
      const res = await supabase.from("pages").select("data, title, head_code, is_front_page").eq("website_id", websiteId).eq("path", "index").single();
      page = res.data;
    }
  }

  if (page) {
    pageCache.set(cacheKey, page);
  }
}

if (!page) {
  return new Response("Page Not Found", { status: 404 });
}

const puckData = page.data;

// Generate CSS (UnoCSS)
// We need to render to string first to generate CSS, but <Render> is a React component.
// Astro can render React components.
// However, to get the CSS *before* sending the response, we might need to render it here.
// But `generateCss` takes HTML string.
// We can use `renderToStaticMarkup` like in editor-save.ts.

import { renderToStaticMarkup } from "react-dom/server";
import React from "react";
import { puckOverrides } from "@components/client/website/pages/overrides/editor-overrides";

const config = getConfig((key: string) => key, []);
const contentHtml = renderToStaticMarkup(
  React.createElement(Render as any, {
    config: config,
    data: puckData,
    overrides: puckOverrides(
      () => {},
      (key: string) => key
    ),
  })
);

const generatedCss = await generateCss(contentHtml);

// Resolve Scripts & External CSS
const scripts = new Set<string>();
const styles = new Set<string>();

const scanData = (items: any[]) => {
  items.forEach((item) => {
    const type = item.type;
    if (scriptRegistry[type]) {
      scriptRegistry[type].forEach((url) => {
        url.endsWith(".css") ? styles.add(url) : scripts.add(url);
      });
    }
    if (item.props?.children && Array.isArray(item.props.children)) {
      scanData(item.props.children);
    }
  });
};
if (puckData.content) scanData(puckData.content);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{page.title || "My Page"}</title>
    {Array.from(styles).map((url) => <link rel="stylesheet" href={url} />)}
    <style set:html={generatedCss}></style>
    {page.head_code && <Fragment set:html={page.head_code} />}
  </head>
  <body>
    <Fragment set:html={contentHtml} />
    {Array.from(scripts).map((url) => <script src={url} defer />)}
  </body>
</html>
